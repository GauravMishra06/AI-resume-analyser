*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional npm cache
.npm

# Archive files
*.zip
*.tar.gz
*.rar

# Python artifacts (legacy - fully disabled)
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
venv/

# Vercel
.vercel/

# TypeScript declaration maps (optional but cleaner)
*.d.ts.map

# Mac hidden files inside folders
**/.DS_Store